{{- if lookPath "runpodctl" }}
# Fetches the running runpod containers and pulls their ssh keys into ssh config
# It populates the config file ~/.ssh/runpod_config with the latest entries,
# and inserts an inclusion statement in to the main ~/.ssh/config file

function runpod-save-ssh() {
  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    cat <<EOF
Fetches the running runpod containers and pulls their ssh keys into ssh config.
It populates the config file ~/.ssh/runpod_config with the latest entries,
and inserts an inclusion statement into the main ~/.ssh/config file.

Usage: runpod-save-ssh
EOF
    return 0
  fi

  local runpod_ssh_config="$HOME/.ssh/runpod_config"
  local ssh_config="$HOME/.ssh/config"
  local temp_config=$(mktemp)

  echo "Getting RunPod SSH connections..."
  local runpod_output=$(runpodctl ssh connect 2>/dev/null)

  # Remove existing runpod config
  [ -f "$runpod_ssh_config" ] && rm "$runpod_ssh_config" && touch "$runpod_ssh_config"

  {{- if .is_wsl }}
  local win_ssh_dir=$(wslpath "$(win_cmd "echo %USERPROFILE%\.ssh")")
  local win_ssh_config="${win_ssh_dir}/config"
  local win_runpod_ssh_config="${win_ssh_dir}/runpod_config"

  [ -f "$win_runpod_ssh_config" ] && rm "$win_runpod_ssh_config" && touch "$win_runpod_ssh_config"
  {{- end }}


  if [ -z "$runpod_output" ]; then
    echo "No RunPod connections found or runpodctl failed"
    mv "$temp_config" "$runpod_ssh_config"
    return 1
  fi

  # Parse runpodctl output and add new entries
  echo "$runpod_output" | while IFS= read -r line; do
    if [[ "$line" =~ ssh[[:space:]]+root@([^[:space:]]+)[[:space:]]+-p[[:space:]]+([0-9]+)[[:space:]]+#[[:space:]]+pod[[:space:]]+[\{][[:space:]]+id:[[:space:]]+\"[^\"]+\",[[:space:]]+name:[[:space:]]+\"([^\"]+)\"[[:space:]]+[\}] ]]; then
      local hostname="${match[1]}"
      local port="${match[2]}"
      local pod_name="${match[3]}"
      local host_alias="runpod_${pod_name}"

      echo "Adding SSH host:\t$host_alias\t$hostname:$port"
      echo "" >> "$temp_config"
      echo "Host $host_alias" >> "$temp_config"
      echo "    HostName $hostname" >> "$temp_config"
      echo "    Port $port" >> "$temp_config"
      echo "    User root" >> "$temp_config"
    fi
  done

  # Replace the original config file
  mv "$temp_config" "$runpod_ssh_config"
  chmod 600 "$runpod_ssh_config"

  # Clean up consecutive empty lines
  sed -i '/^$/N;/^\n$/d' "$runpod_ssh_config"

  sed -i '1i\
  # This file is generated and managed by runpod-save-ssh()\
  # It contains SSH configuration settings for RunPod instances.\
  # Do not edit this file manually as changes may be overwritten.' \
  "$runpod_ssh_config"

  echo "Updated ssh with runpod connections:\t${runpod_ssh_config}"

  if [ ! -f "$ssh_config" ]; then
    echo "Include $runpod_ssh_config" > "$ssh_config"
  else
    if ! grep -qF "Include runpod_config" "$ssh_config"; then
      echo "Include runpod_config\n" > "$temp_config"
      cat "$ssh_config" >> "$temp_config"
      mv "$temp_config" "$ssh_config"
      echo "Added Include runpod_config to the top of\t$ssh_config"
    fi
  fi

  {{- if .is_wsl }}
  echo "Deployed runpod SSH config to Windows:\t${win_runpod_ssh_config}"
  cp "$runpod_ssh_config" "${win_runpod_ssh_config}"

  if [ ! -f "$win_ssh_config" ]; then
    echo "Include $win_runpod_ssh_config" > "$win_ssh_config"
  else
    if ! grep -qF "Include runpod_config" "$win_ssh_config"; then
      echo "Include runpod_config\n" > "$temp_config"
      cat "$win_ssh_config" >> "$temp_config"
      mv "$temp_config" "$win_ssh_config"
      echo "Added Include runpod_config to the top of\t$win_ssh_config"
    fi
  fi
  {{- end }}
}
{{- end }}
